# Copy this file to .env and fill in real values.
# .env is gitignored and must NEVER be committed.

# Application
APP_NAME=Code2Py
ENVIRONMENT=development

# CORS — comma-separated allowed frontend origins.
# In production add your Vercel URL, e.g. https://code2py.vercel.app
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# AI provider: "ollama" (local dev) or "groq" (free hosted, for deployment)
AI_PROVIDER=ollama
OLLAMA_MODEL=qwen2.5-coder:7b
# For deployment with Groq (get a free key at console.groq.com):
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Database (local Postgres). Format:
#   postgresql+psycopg://USER[:PASSWORD]@HOST:PORT/DBNAME
DATABASE_URL=postgresql+psycopg://USER@localhost:5432/code2py

# JWT — generate your own with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
